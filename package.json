{
	"name": "@ebnsina/livekit-svelte",
	"version": "0.0.1",
	"description": "LiveKit components for Svelte 5 — build realtime video, audio, and agent experiences.",
	"license": "MIT",
	"author": "ebnsina <ebnsina.me@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github-es/ebnsina/livekit-svelte.git"
	},
	"keywords": [
		"livekit",
		"svelte",
		"webrtc",
		"video",
		"components"
	],
	"type": "module",
	"packageManager": "pnpm@11.10.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./styles.css": "./dist/styles/livekit-svelte.css",
		"./components.css": "./dist/styles/components.css"
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0"
	},
	"dependencies": {
		"@livekit/components-core": "^0.12.14",
		"@lucide/svelte": "^1.25.0",
		"livekit-client": "^2.20.2",
		"rxjs": "^7.8.2"
	},
	"devDependencies": {
		"@fontsource-variable/mona-sans": "5.3.0",
		"@fontsource/ibm-plex-mono": "5.3.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"publint": "^0.3.21",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
