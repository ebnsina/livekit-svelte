{
	"name": "@ebnsina/livekit-svelte",
	"version": "0.0.1",
	"description": "LiveKit components for Svelte 5 — a full-parity port of @livekit/components-react.",
	"license": "MIT",
	"author": "ebnsina <ebnsina.me@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github-es/ebnsina/livekit-svelte.git"
	},
	"keywords": [
		"livekit",
		"svelte",
		"webrtc",
		"video",
		"components"
	],
	"type": "module",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./styles.css": "./dist/styles/livekit-svelte.css"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"prepublishOnly": "npm run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run"
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0"
	},
	"dependencies": {
		"@livekit/components-core": "^0.12.14",
		"@lucide/svelte": "^1.25.0",
		"livekit-client": "^2.20.2",
		"rxjs": "^7.8.2"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/kit": "^2.70.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.3",
		"publint": "^0.3.0",
		"svelte": "^5.56.0",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.3.3",
		"typescript": "^5.6.0",
		"vite": "^7.0.0",
		"vitest": "^2.1.0"
	}
}
